# ШАБЛОН секретов Pulse. На сервере скопировать в bootstrap.env, вписать значения, chmod 600.
# НИКОГДА не коммитить настоящий bootstrap.env (он в .gitignore).

# Токен бота от @BotFather (вида 8123456789:AAH......)
PULSE_TG_TOKEN=

# Ключ Anthropic (тот же, что у проекта; вида sk-ant-api03-......)
ANTHROPIC_API_KEY=

# chat_id владельца. Оставь ПУСТЫМ при первом запуске — напиши боту "привет",
# он ответит твоим chat_id, впиши его сюда и перезапусти Pulse.
OWNER_CHAT_ID=
